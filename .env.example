# Google Places (legacy Places API: Text Search + Place Details)
GOOGLE_PLACES_API_KEY=

# OpenAI for inventory extraction from HTML
OPENAI_API_KEY=

# At least one managed scraper (used in order: ZenRows, then ScrapingBee, then direct fetch)
ZENROWS_API_KEY=
SCRAPINGBEE_API_KEY=

# Next.js: API base. On Vercel Services this is often `/server` (or auto-set). Locally omit for http://localhost:8000.
# NEXT_PUBLIC_API_URL=/server

# FastAPI: must match vercel.json `routePrefix` when using Vercel Services (see vercel.json env).
# MOTORSCRAPE_API_PREFIX=/server
