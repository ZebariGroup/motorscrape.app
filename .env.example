# Google Places API (New): Text Search + Place Details — enable "Places API" in Google Cloud
# Either name works (same key from Google Cloud if Places + Details are enabled):
GOOGLE_PLACES_API_KEY=
# GOOGLE_MAPS_API_KEY=

# OpenAI for inventory extraction from HTML
OPENAI_API_KEY=
# Optional; default gpt-4o-mini for faster extraction
# OPENAI_EXTRACTION_MODEL=gpt-4o-mini
# Optional; default 75 — abort stuck LLM calls so the search can continue
# OPENAI_TIMEOUT=75

# Managed scrapers run after optional self-hosted Playwright (below) when direct HTTP is insufficient.
# Order when needed: Playwright (if PLAYWRIGHT_ENABLED) → ZenRows static → ZenRows JS → ScrapingBee.
ZENROWS_API_KEY=
# Optional; default false — enable only if your ZenRows plan supports premium proxy
# ZENROWS_PREMIUM_PROXY=false
# Milliseconds to wait after JS render (only when js_render is on); default 3000
# ZENROWS_WAIT_MS=3000
# Max concurrent in-flight ZenRows calls; match your plan's concurrency limit.
# ZENROWS_MAX_CONCURRENCY=5
# Retry transient ZenRows throttling/network blips.
# ZENROWS_REQUEST_ATTEMPTS=2
# ZENROWS_RETRY_BACKOFF_MS=1200
# Cooldown after repeated ZenRows throttling errors.
# ZENROWS_COOLDOWN_SECONDS=15
SCRAPINGBEE_API_KEY=
# SCRAPINGBEE_WAIT_MS=3000
# SCRAPINGBEE_MAX_CONCURRENCY=4
# Shared cap across managed providers (ZenRows + ScrapingBee).
# MANAGED_SCRAPER_MAX_CONCURRENCY=6
# Keep homepage JS rendering off by default to reduce managed scraper spend.
# HOMEPAGE_MANAGED_JS_RENDER=false

# Self-hosted headless Chromium (Playwright). Install browsers once: `cd backend && playwright install chromium`
# Off by default (required for Vercel serverless). Enable on your own VPS/VM to cut ZenRows/ScrapingBee usage.
# Playwright now applies platform-aware interaction recipes locally before falling back to managed renderers.
# PLAYWRIGHT_ENABLED=true
# PLAYWRIGHT_MAX_WORKERS=4
# PLAYWRIGHT_TIMEOUT_MS=45000
# Baseline settle wait before platform-specific clicks/scrolls/waits run.
# PLAYWRIGHT_POST_LOAD_WAIT_MS=2500

# Search pacing controls (defaults tuned to keep slow dealerships from clogging the worker pool)
# SEARCH_CONCURRENCY=8
# Cap worker fan-out against managed scraper slots: effective workers <=
# MANAGED_SCRAPER_MAX_CONCURRENCY * SEARCH_WORKERS_PER_MANAGED_SLOT.
# SEARCH_WORKERS_PER_MANAGED_SLOT=2
# Limit simultaneous HTTP fetches per normalized dealer host (anti-hammering). Default 1.
# DOMAIN_FETCH_CONCURRENCY=1
# DEALERSHIP_TIMEOUT=150
# Default 3 pages per dealer for deeper SRP coverage (structured + paginated stacks).
# MAX_PAGES_PER_DEALER=3
# Hard cap for API max_pages_per_dealer override (serverless safety).
# SEARCH_MAX_PAGES_PER_DEALER_CAP=10
# SCRAPE_TIMEOUT=30
# MAX_HTML_CHARS=60000

# Multi-vehicle rollout flags. Backend categories stay gated until explicitly enabled.
# Example phased rollout: `car,motorcycle` first, then `car,motorcycle,boat`.
# ENABLED_VEHICLE_CATEGORIES=car

# Provider/platform cache. The backend fingerprints dealer sites and caches
# domain -> platform + strategy hints here for faster repeat searches.
# PLATFORM_CACHE_ENABLED=true
# Local default: backend/data/platform-cache.sqlite3 (created automatically).
# Vercel default: /tmp/motorscrape-platform-cache.sqlite3 unless VERCEL_* is unset.
# PLATFORM_CACHE_PATH=/tmp/motorscrape-platform-cache.sqlite3
# PLATFORM_CACHE_TTL_HOURS=336
# PLATFORM_CACHE_FAILURE_THRESHOLD=3
#
# Inventory listings cache (short TTL). Keyed by dealer URL + query params; reduces repeat scrapes.
# INVENTORY_CACHE_ENABLED=true
# INVENTORY_CACHE_TTL_SECONDS=7200
# INVENTORY_CACHE_PATH=/tmp/motorscrape-inventory-cache.sqlite3
#
# Production (Vercel KV / Upstash): when set, Redis is used instead of ephemeral SQLite.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- Accounts & billing ---
# Required for sign-up / login (use a long random string in production).
# SESSION_SECRET=

# Optional override for SQLite path (default: backend/data/accounts.sqlite3 locally, /tmp on Vercel).
# ACCOUNTS_DB_PATH=

# Stripe (self-serve Standard/Premium). Create products/prices in Dashboard, then paste price IDs.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_STANDARD_BASE=
# STRIPE_PRICE_STANDARD_METERED=
# STRIPE_PRICE_PREMIUM_BASE=
# STRIPE_PRICE_PREMIUM_METERED=

# Used in Stripe Checkout success/cancel URLs (e.g. https://your-deployment.vercel.app).
# PUBLIC_WEB_URL=http://localhost:3000

# Scheduled email alerts (Resend-compatible).
# RESEND_API_KEY=
# ALERTS_FROM_EMAIL=alerts@yourdomain.example
# ALERTS_INTERNAL_SECRET=

# Next.js: API base.
# - Vercel Services: `/server` (also set in vercel.json).
# - Local dev with Next rewrites: set `/server` and run FastAPI on 127.0.0.1:8000 (see frontend/next.config.ts).
# NEXT_PUBLIC_API_URL=/server
#
# Optional: origin for Next.js dev rewrites if FastAPI is not on 127.0.0.1:8000
# MOTORSCRAPE_API_ORIGIN=http://127.0.0.1:8000
