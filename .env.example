# Google Places API (New): Text Search + Place Details — enable "Places API" in Google Cloud
# Either name works (same key from Google Cloud if Places + Details are enabled):
GOOGLE_PLACES_API_KEY=
# GOOGLE_MAPS_API_KEY=

# OpenAI for inventory extraction from HTML
OPENAI_API_KEY=
# Optional; default 120 — abort stuck LLM calls so the search can continue
# OPENAI_TIMEOUT=120

# At least one managed scraper (used in order: ZenRows, then ScrapingBee, then direct fetch)
ZENROWS_API_KEY=
SCRAPINGBEE_API_KEY=

# Next.js: API base. On Vercel Services use `/server` (also set in vercel.json). Locally omit for http://localhost:8000.
# NEXT_PUBLIC_API_URL=/server
