{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "web": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "api": {
      "entrypoint": "backend/main.py",
      "routePrefix": "/server",
      "framework": "fastapi",
      "maxDuration": 300,
      "excludeFiles": "{frontend/**,backend/tests/**,backend/.coverage,docs/**,supabase/**,.github/**,**/.venv/**,**/.git/**,**/__pycache__/**,**/*.pyc,**/.next/**,**/*.md}"
    }
  },
  "env": {
    "NEXT_PUBLIC_API_URL": "/server"
  },
  "installCommand": "pip install -r backend/requirements.txt && cd frontend && npm install"
}
